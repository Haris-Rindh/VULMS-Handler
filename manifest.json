{
  "manifest_version": 3,
  "name": "VU LMS Deadline Notifier",
  "version": "1.0.0",
  "description": "Automatically detects VU LMS assignments, quizzes, and GDBs. Notifies with escalating reminders until submitted or deadline passes.",
  "permissions": ["storage", "alarms", "notifications", "offscreen"],
  "host_permissions": ["*://vulms.vu.edu.pk/*", "*://vu.edu.pk/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://vulms.vu.edu.pk/*"],
      "js": ["utils/parser.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "VU LMS Deadline Notifier"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["utils/audio.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
