# ── Credentials & Secrets ──────────────────────────────────────────────────────
# NEVER commit this file. It is in .gitignore.

# 32-byte hex key for AES-256-GCM credential encryption.
# Generate once on the VM:   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Back this up OUTSIDE the VM immediately after generating it.
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_on_vm

# VAPID keys for web-push notifications.
# Generate once:   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace_with_vapid_public_key
VAPID_PRIVATE_KEY=replace_with_vapid_private_key
VAPID_EMAIL=mailto:your_email@example.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001

# Origin of the Vercel frontend (used for CORS whitelist).
# Example: https://vu-notifier.vercel.app
FRONTEND_ORIGIN=https://your-vercel-app.vercel.app

# ── Cron schedule (node-cron syntax, PKT = UTC+5) ────────────────────────────
# Default: 8 AM and 8 PM Pakistan Standard Time
# PKT 08:00 = UTC 03:00  →  "0 3 * * *"
# PKT 20:00 = UTC 15:00  →  "0 15 * * *"
CRON_SCHEDULE_MORNING=0 3 * * *
CRON_SCHEDULE_EVENING=0 15 * * *
